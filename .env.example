# ===========================================
# TramiFlow CE - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ===========================================
# Supabase Configuration
# ===========================================
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# Application Configuration
# ===========================================
# Base URL of your application (used for redirects, emails, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===========================================
# Rate Limiting (Optional)
# ===========================================
# For production, consider using Upstash Redis for distributed rate limiting
# Get your free tier at: https://upstash.com/
# If not set, will use in-memory rate limiting (resets on server restart)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ===========================================
# Error Tracking (Optional)
# ===========================================
# Sentry for error tracking and performance monitoring
# Get your DSN at: https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_PROJECT=

# ===========================================
# Analytics (Optional)
# ===========================================
# Vercel Analytics (automatically configured if deployed on Vercel)
# Google Analytics
NEXT_PUBLIC_GA_ID=

# Posthog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ===========================================
# Email (Future Feature)
# ===========================================
# For sending emails (lead notifications, etc.)
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# ===========================================
# OAuth Providers (Optional)
# ===========================================
# Google OAuth (configured in Supabase)
# Get credentials at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# Feature Flags
# ===========================================
# Enable/disable features without deployment
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SHARING=true
NEXT_PUBLIC_ENABLE_BRANDING=true

# ===========================================
# Development Only
# ===========================================
# Enable debug logging (do NOT enable in production)
DEBUG=false

# Database connection timeout (ms)
DB_TIMEOUT=10000
